# Family Health Manager - Environment Configuration
# Copy this file to .env and update with your actual values

# ==================== PostgreSQL Database Configuration ====================
# Primary relational database for structured health data

# Database Connection Settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=family_health_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# Connection Pool Settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ==================== Neo4j Database Configuration ====================
# Graph database for relationships, family trees, and knowledge graphs

# Neo4j Connection Settings
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j

# Neo4j Connection Pool Settings
NEO4J_MAX_CONNECTION_LIFETIME=3600
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_ACQUISITION_TIMEOUT=60

# ==================== Redis Configuration ====================
# In-memory cache and session store for fast data access

# Redis Connection Settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Redis Configuration
REDIS_DECODE_RESPONSES=true
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_MAX_CONNECTIONS=50
REDIS_RETRY_ON_TIMEOUT=true
